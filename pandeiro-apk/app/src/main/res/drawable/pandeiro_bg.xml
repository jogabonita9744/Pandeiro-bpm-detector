<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer dark rim -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#4A2A0A"/>
            <stroke android:width="3dp" android:color="#7A4E22"/>
        </shape>
    </item>
    <!-- Inner skin -->
    <item android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp">
        <shape android:shape="oval">
            <solid android:color="#C8874A"/>
            <gradient
                android:type="radial"
                android:gradientRadius="110dp"
                android:startColor="#F0D0A0"
                android:centerColor="#C8874A"
                android:endColor="#7A4E22"
                android:centerX="0.4"
                android:centerY="0.35"/>
        </shape>
    </item>
</layer-list>
